# App
APP_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://openaiops:openaiops@localhost:5432/openaiops?schema=public

# Development ingest key. Replace in production and store in a secret manager.
INGEST_API_KEYS=dev_ingest_key

# Optional analytics
VERCEL_ANALYTICS_ID=
